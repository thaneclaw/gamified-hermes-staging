# Cache headers for Cloudflare Pages
#
# index.html is the SPA entry — must always revalidate so a fresh deploy
# is picked up on the next page load. Hashed assets in /assets/* never
# change once published, so let CDNs hold them forever.

/index.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable
